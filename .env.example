# API服务地址配置
# 生产环境请设置为实际的API地址，开发环境可以不设置，会自动使用 window.location.origin/api
REACT_APP_API_URL=

# 聊天服务地址
REACT_APP_CHAT_URL=http://127.0.0.1:8000

# AI模型服务地址
REACT_APP_MODEL_SERVICE_URL=http://127.0.0.1:8001

# 微信支付服务地址
REACT_APP_WXPAY_URL=http://127.0.0.1:8002

# 后端Go服务地址
REACT_APP_GOBACK_URL=http://127.0.0.1:8080

# Coze AI API配置
REACT_APP_COZE_API_URL=https://api.coze.cn/open_api/v2/chat
REACT_APP_COZE_TOKEN=your_coze_token_here
REACT_APP_COZE_BOT_ID_KEYWORD=your_bot_id_keyword_here
REACT_APP_COZE_BOT_ID_TEMPLATE=your_bot_id_template_here

# 扩展插件下载地址
REACT_APP_EXTENSION_DOWNLOAD_URL=https://iry-1256349444.cos.ap-guangzhou.myqcloud.com/%E5%86%85%E5%AE%B9%E6%94%B6%E9%9B%86%E6%8F%92%E4%BB%B6.zip

# 小红书基础URL
REACT_APP_XHS_BASE_URL=https://www.xiaohongshu.com/explore/

# 外部链接
REACT_APP_DOCS_URL=your_docs_url_here
REACT_APP_EXTENSION_TUTORIAL_URL=your_extension_tutorial_url_here
REACT_APP_MESSAGE_PROGRAM_DOWNLOAD_URL=your_message_program_download_url_here

# UI资源
REACT_APP_LOGIN_BG_IMAGE_URL=your_login_bg_image_url_here
REACT_APP_UPLOAD_FORMAT_IMAGE_URL=your_upload_format_image_url_here
